# Application Configuration
APP_NAME="GSD-Docs Industrial"
DEBUG=false
VERSION="2.0.0-dev"

# Database
# SQLite database file path (relative to backend directory)
DATABASE_URL="sqlite+aiosqlite:///./gsd_docs.db"

# LLM Provider Configuration
# Provider: anthropic, openai, etc. (see LiteLLM docs)
LLM_PROVIDER="anthropic"
# Model identifier in LiteLLM format (provider/model-name)
LLM_MODEL="anthropic/claude-sonnet-4-20250514"
# API key for Anthropic (leave empty for development without LLM features)
ANTHROPIC_API_KEY=""

# CORS Configuration
# Comma-separated list of allowed origins for frontend
CORS_ORIGINS='["http://localhost:5173"]'

# File Upload Configuration
# Maximum file size in bytes (default: 10MB)
MAX_UPLOAD_SIZE=10485760
# Directory for uploaded files (relative to backend directory)
UPLOAD_DIR="./uploads"
