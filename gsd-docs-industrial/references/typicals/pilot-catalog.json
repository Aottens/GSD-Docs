            "description": "TRUE when sequence active"
          },
          {
            "name": "SequenceComplete",
            "dataType": "BOOL",
            "description": "TRUE when sequence finished"
          },
          {
            "name": "SequenceHeld",
            "dataType": "BOOL",
            "description": "TRUE when sequence held"
          }
        ]
      },
      "use_cases": [
