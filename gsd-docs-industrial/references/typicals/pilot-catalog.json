        "Startup sequences"
      ],
      "states": [
        {
          "name": "IDLE",
          "description": "Sequence not running"
        },
        {
          "name": "RUNNING",
          "description": "Sequence executing steps"
        },
        {
          "name": "HELD",
          "description": "Sequence paused"
        },
        {
          "name": "COMPLETE",
          "description": "Sequence finished successfully"
        },
        {
          "name": "ABORTED",
          "description": "Sequence aborted by operator"
        }
      ],
      "documentation": null
    }
  ]
